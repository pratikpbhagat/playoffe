{
  "name": "pickleball-platform",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "lint:rls": "node scripts/lint-rls-policies.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "next": "14.2.18"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "@supabase/supabase-js": "2.47.10",
      "ioredis": "5.3.2"
    },
    "onlyBuiltDependencies": ["esbuild", "sharp", "@resvg/resvg-js", "msgpackr-extract"]
  }
}
